#!/bin/sh
# =============================================================================
# pre-commit — Enterprise Git Hook
# Runs before every commit is created.
# Checks: secrets, forbidden patterns, lint, type-check, file size limits.
# =============================================================================

set -e

ROOT_DIR="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "${CYAN}  BetterLibmanan — Pre-Commit Checks${NC}"
echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ -z "$STAGED_FILES" ]; then
  echo "${GREEN}✅ No staged files. Nothing to check.${NC}"
  exit 0
fi

ERRORS=0

# -----------------------------------------------------------------------------
# 1. SECRET / CREDENTIAL DETECTION
#    Catches hardcoded API keys, tokens, passwords, private keys before they
#    ever enter the repository history.
# -----------------------------------------------------------------------------
echo "\n🔐 [1/5] Scanning for secrets and credentials..."

# Match credential-like assignments where the quoted value is 8+ chars and
# contains NO whitespace — real secrets don't have spaces, but UI strings
# like `next.password = "Password is required."` do. This avoids most false
# positives in form validation / React component code.
SECRET_PATTERNS='(password|passwd|secret|api[_-]?key|apikey|auth[_-]?token|access[_-]?token|private[_-]?key|aws[_-]?secret|client[_-]?secret)\s*[:=]\s*["\x27][A-Za-z0-9_+/.=-]{8,}["\x27]'
PRIVATE_KEY_PATTERN='-----BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY-----'
# Common high-entropy patterns (base64-like strings 40+ chars)
HIGH_ENTROPY_PATTERN='[A-Za-z0-9+/]{40,}={0,2}'

SECRET_FILES=""
for FILE in $STAGED_FILES; do
  # Skip binary and lock files
  case "$FILE" in
    *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot|*.pdf|*.zip|*.tar|*.gz) continue ;;
    *pnpm-lock.yaml|*package-lock.json|*yarn.lock) continue ;;
    *.env.example) continue ;;
  esac

  if git show ":$FILE" | grep -qiE "$SECRET_PATTERNS" 2>/dev/null; then
    SECRET_FILES="$SECRET_FILES\n  ⚠️  $FILE (suspicious credential pattern)"
    ERRORS=$((ERRORS + 1))
  fi

  if git show ":$FILE" | grep -qE "$PRIVATE_KEY_PATTERN" 2>/dev/null; then
    SECRET_FILES="$SECRET_FILES\n  ⚠️  $FILE (private key detected)"
    ERRORS=$((ERRORS + 1))
  fi
done

if [ -n "$SECRET_FILES" ]; then
  echo "${RED}❌ Potential secrets detected in staged files:${NC}"
  printf "$SECRET_FILES\n"
  echo "${YELLOW}   → Use environment variables and .env files (gitignored) instead.${NC}"
  echo "${YELLOW}   → To bypass (only if false positive): git commit --no-verify${NC}"
else
  echo "${GREEN}✅ No secrets detected.${NC}"
fi

# -----------------------------------------------------------------------------
# 2. .ENV FILE STAGING GUARD
#    Prevents accidentally committing real .env files.
# -----------------------------------------------------------------------------
echo "\n🔒 [2/5] Checking for .env file staging..."

ENV_VIOLATIONS=""
for FILE in $STAGED_FILES; do
  BASENAME=$(basename "$FILE")
  case "$BASENAME" in
    .env|.env.local|.env.development|.env.production|.env.staging|.env.test)
      ENV_VIOLATIONS="$ENV_VIOLATIONS\n  ❌ $FILE"
      ERRORS=$((ERRORS + 1))
      ;;
  esac
done

if [ -n "$ENV_VIOLATIONS" ]; then
  echo "${RED}❌ Real .env files must NOT be committed:${NC}"
  printf "$ENV_VIOLATIONS\n"
  echo "${YELLOW}   → Add them to .gitignore. Only .env.example should be committed.${NC}"
else
  echo "${GREEN}✅ No .env files staged.${NC}"
fi

# -----------------------------------------------------------------------------
# 3. FORBIDDEN DEBUG / DEVELOPMENT ARTIFACTS
#    Catches console.log, debugger statements, TODO/FIXME, and skipped tests
#    in TypeScript/JavaScript source files.
# -----------------------------------------------------------------------------
echo "\n🚫 [3/5] Scanning for forbidden debug patterns..."

TS_JS_FILES=""
for FILE in $STAGED_FILES; do
  case "$FILE" in
    *.ts|*.tsx|*.js|*.jsx)
      # Exclude test/spec files and config files — they may legitimately have these
      case "$FILE" in
        *.test.*|*.spec.*|*.config.*|*.d.ts) continue ;;
      esac
      TS_JS_FILES="$TS_JS_FILES $FILE"
      ;;
  esac
done

FORBIDDEN_FOUND=0
if [ -n "$TS_JS_FILES" ]; then
  for FILE in $TS_JS_FILES; do
    FILE_CONTENT=$(git show ":$FILE" 2>/dev/null)

    # console.log / console.debug (allow console.warn and console.error in production code)
    if echo "$FILE_CONTENT" | grep -nE '^\s*console\.(log|debug|trace|dir|table)\(' 2>/dev/null | grep -qv '//'; then
      LINE=$(echo "$FILE_CONTENT" | grep -nE '^\s*console\.(log|debug|trace|dir|table)\(' | head -1)
      echo "${YELLOW}  ⚠️  $FILE: console.log/debug detected → $LINE${NC}"
      FORBIDDEN_FOUND=$((FORBIDDEN_FOUND + 1))
    fi

    # debugger statement
    if echo "$FILE_CONTENT" | grep -qE '^\s*debugger\s*;?' 2>/dev/null; then
      echo "${RED}  ❌ $FILE: 'debugger' statement detected${NC}"
      ERRORS=$((ERRORS + 1))
      FORBIDDEN_FOUND=$((FORBIDDEN_FOUND + 1))
    fi

    # .only() in tests (accidentally skipping all other tests)
    if echo "$FILE_CONTENT" | grep -qE '\.(only|skip)\s*\(' 2>/dev/null; then
      echo "${RED}  ❌ $FILE: .only() or .skip() in test file — would skip CI tests${NC}"
      ERRORS=$((ERRORS + 1))
      FORBIDDEN_FOUND=$((FORBIDDEN_FOUND + 1))
    fi
  done
fi

if [ "$FORBIDDEN_FOUND" -eq 0 ]; then
  echo "${GREEN}✅ No forbidden debug patterns found.${NC}"
fi

# -----------------------------------------------------------------------------
# 4. LARGE FILE CHECK
#    Prevents accidentally committing large binary or generated files.
#    Limit: 5 MB per file.
# -----------------------------------------------------------------------------
echo "\n📦 [4/5] Checking file sizes..."

MAX_SIZE_KB=5120  # 5 MB
LARGE_FILES=""

for FILE in $STAGED_FILES; do
  # Get file size in bytes from git index
  SIZE=$(git cat-file -s ":$FILE" 2>/dev/null || echo 0)
  SIZE_KB=$((SIZE / 1024))

  if [ "$SIZE_KB" -gt "$MAX_SIZE_KB" ]; then
    LARGE_FILES="$LARGE_FILES\n  ❌ $FILE (${SIZE_KB} KB — limit is ${MAX_SIZE_KB} KB)"
    ERRORS=$((ERRORS + 1))
  fi
done

if [ -n "$LARGE_FILES" ]; then
  echo "${RED}❌ Oversized files detected:${NC}"
  printf "$LARGE_FILES\n"
  echo "${YELLOW}   → Use Git LFS for large assets: git lfs track '*.extension'${NC}"
else
  echo "${GREEN}✅ All file sizes within limits.${NC}"
fi

# -----------------------------------------------------------------------------
# 5. TYPESCRIPT TYPE-CHECK (incremental, non-blocking on missing tsc)
#    Only runs if TypeScript files are staged and tsc is available.
# -----------------------------------------------------------------------------
echo "\n🔷 [5/5] TypeScript type-check..."

HAS_TS_FILES=0
for FILE in $STAGED_FILES; do
  case "$FILE" in
    *.ts|*.tsx)
      HAS_TS_FILES=1
      break
      ;;
  esac
done

if [ "$HAS_TS_FILES" -eq 1 ]; then
  if command -v pnpm >/dev/null 2>&1; then
    cd "$ROOT_DIR"
    # Run tsc directly on each app/package that has a tsconfig.
    # Avoids turbo which may hang if its platform binary is missing.
    TYPECHECK_FAILED=0
    for TSCONFIG in apps/*/tsconfig.json packages/*/tsconfig.json; do
      [ -f "$TSCONFIG" ] || continue
      PKG_DIR=$(dirname "$TSCONFIG")
      TYPECHECK_OUTPUT=$(pnpm exec tsc --noEmit --project "$TSCONFIG" 2>&1)
      if [ $? -ne 0 ]; then
        echo "$TYPECHECK_OUTPUT" | grep -E "error TS" | head -10
        TYPECHECK_FAILED=1
      fi
    done
    if [ "$TYPECHECK_FAILED" -eq 1 ]; then
      echo "${RED}❌ TypeScript errors found. Fix them before committing.${NC}"
      ERRORS=$((ERRORS + 1))
    else
      echo "${GREEN}✅ TypeScript types OK.${NC}"
    fi
  else
    echo "${YELLOW}⚠️  pnpm not found, skipping type-check.${NC}"
  fi
else
  echo "${GREEN}✅ No TypeScript files staged, skipping type-check.${NC}"
fi

# -----------------------------------------------------------------------------
# RESULT
# -----------------------------------------------------------------------------
echo "\n${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ "$ERRORS" -gt 0 ]; then
  echo "${RED}❌ Pre-commit failed with $ERRORS error(s). Commit aborted.${NC}"
  echo "${YELLOW}   Fix the issues above or use --no-verify to bypass (not recommended).${NC}"
  echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 1
else
  echo "${GREEN}✅ All pre-commit checks passed. Proceeding with commit.${NC}"
  echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 0
fi
