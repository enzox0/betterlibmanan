#!/bin/sh
# =============================================================================
# commit-msg — Enterprise Git Hook
# Enforces Conventional Commits specification with additional enterprise rules:
#   - Subject line length limit (72 chars)
#   - Body line length limit (100 chars)
#   - No period at end of subject
#   - WIP commits blocked on protected branches
#   - Scope validation against known project areas
# =============================================================================

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "${CYAN}  BetterLibmanan — Commit Message Validation${NC}"
echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

ERRORS=0

# Skip merge commits, revert commits, and fixup/squash commits
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)

case "$FIRST_LINE" in
  Merge*|Revert*|fixup\!*|squash\!*)
    echo "${GREEN}✅ Auto-generated commit message, skipping validation.${NC}"
    exit 0
    ;;
esac

# -----------------------------------------------------------------------------
# 1. CONVENTIONAL COMMIT FORMAT
# Types from: https://www.conventionalcommits.org/
# Also includes 'wip' as a valid type (blocked on protected branches below)
# -----------------------------------------------------------------------------
VALID_TYPES="feat|fix|chore|docs|style|refactor|perf|test|ci|build|revert|wip|hotfix|security|deps"
CONVENTIONAL_REGEX="^(${VALID_TYPES})(\([a-zA-Z0-9_\/-]+\))?!?: .+"

if ! echo "$FIRST_LINE" | grep -qE "$CONVENTIONAL_REGEX"; then
  echo "${RED}❌ Invalid commit message format.${NC}"
  echo ""
  echo "   Expected:  <type>(<scope>): <description>"
  echo "   Received:  $FIRST_LINE"
  echo ""
  echo "   Valid types: feat, fix, chore, docs, style, refactor,"
  echo "                perf, test, ci, build, revert, wip, hotfix,"
  echo "                security, deps"
  echo ""
  echo "   Examples:"
  echo "     feat(auth): add JWT refresh token rotation"
  echo "     fix(api): handle null response from DPWH endpoint"
  echo "     docs(readme): update local setup instructions"
  echo "     ci(pipeline): add security scanning step"
  echo "     feat!: remove deprecated v1 endpoints  (breaking change)"
  ERRORS=$((ERRORS + 1))
fi

# -----------------------------------------------------------------------------
# 2. SUBJECT LINE LENGTH (max 72 characters)
# -----------------------------------------------------------------------------
SUBJECT_LENGTH=$(echo "$FIRST_LINE" | wc -c | tr -d ' ')
if [ "$SUBJECT_LENGTH" -gt 72 ]; then
  echo "${RED}❌ Subject line too long: ${SUBJECT_LENGTH} chars (max: 72).${NC}"
  echo "   → Keep the subject concise. Put details in the body."
  ERRORS=$((ERRORS + 1))
fi

# -----------------------------------------------------------------------------
# 3. NO TRAILING PERIOD ON SUBJECT
# -----------------------------------------------------------------------------
if echo "$FIRST_LINE" | grep -qE '\.$'; then
  echo "${RED}❌ Subject line must not end with a period.${NC}"
  ERRORS=$((ERRORS + 1))
fi

# -----------------------------------------------------------------------------
# 4. BLANK LINE BETWEEN SUBJECT AND BODY (if body exists)
# -----------------------------------------------------------------------------
LINE_COUNT=$(echo "$COMMIT_MSG" | wc -l | tr -d ' ')
if [ "$LINE_COUNT" -gt 1 ]; then
  SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n '2p')
  if [ -n "$SECOND_LINE" ]; then
    echo "${RED}❌ Missing blank line between subject and body.${NC}"
    echo "   → The second line of a commit message must be blank."
    ERRORS=$((ERRORS + 1))
  fi
fi

# -----------------------------------------------------------------------------
# 5. BODY LINE LENGTH (max 100 characters)
# -----------------------------------------------------------------------------
LONG_BODY_LINES=$(echo "$COMMIT_MSG" | tail -n +3 | awk 'length > 100 {print NR+2": "$0}')
if [ -n "$LONG_BODY_LINES" ]; then
  echo "${YELLOW}⚠️  Body lines exceed 100 characters (advisory):${NC}"
  echo "$LONG_BODY_LINES" | head -5
fi

# -----------------------------------------------------------------------------
# 6. BREAKING CHANGE: require body note when ! is used
# -----------------------------------------------------------------------------
if echo "$FIRST_LINE" | grep -qE '!:'; then
  if [ "$LINE_COUNT" -lt 3 ]; then
    echo "${RED}❌ Breaking change (!) must include a body explaining the impact.${NC}"
    echo "   → Add a blank line after the subject, then describe what breaks."
    ERRORS=$((ERRORS + 1))
  fi
fi

# -----------------------------------------------------------------------------
# 7. WIP COMMITS BLOCKED ON PROTECTED BRANCHES
# -----------------------------------------------------------------------------
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
PROTECTED_BRANCHES="main master develop staging production"

IS_PROTECTED=0
for BRANCH in $PROTECTED_BRANCHES; do
  if [ "$CURRENT_BRANCH" = "$BRANCH" ]; then
    IS_PROTECTED=1
    break
  fi
done

if [ "$IS_PROTECTED" -eq 1 ]; then
  if echo "$FIRST_LINE" | grep -qiE '^wip(\(|:|\!:)'; then
    echo "${RED}❌ WIP commits are not allowed on protected branch '${CURRENT_BRANCH}'.${NC}"
    echo "   → Finish your work or use a feature branch."
    ERRORS=$((ERRORS + 1))
  fi
fi

# -----------------------------------------------------------------------------
# 8. EMPTY DESCRIPTION CHECK
# -----------------------------------------------------------------------------
DESCRIPTION=$(echo "$FIRST_LINE" | sed -E "s/^(${VALID_TYPES})(\([^)]+\))?!?:\s*//")
if [ -z "$DESCRIPTION" ] || [ "$DESCRIPTION" = "$FIRST_LINE" ]; then
  echo "${RED}❌ Commit description is empty.${NC}"
  echo "   → Add a meaningful description after the type and colon."
  ERRORS=$((ERRORS + 1))
elif [ ${#DESCRIPTION} -lt 10 ]; then
  echo "${YELLOW}⚠️  Commit description is very short (${#DESCRIPTION} chars). Be more descriptive.${NC}"
fi

# -----------------------------------------------------------------------------
# RESULT
# -----------------------------------------------------------------------------
echo ""
if [ "$ERRORS" -gt 0 ]; then
  echo "${RED}❌ Commit message validation failed ($ERRORS error(s)).${NC}"
  echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 1
else
  echo "${GREEN}✅ Commit message is valid.${NC}"
  echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  exit 0
fi
