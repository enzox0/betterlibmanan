{
  "name": "betterlibmanan",
  "version": "1.0.0",
  "private": true,
  "description": "BetterLibmanan - Enterprise Monolith for Local Government",
  "author": "BetterLibmanan Team",
  "license": "CC0-1.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@betterlibmanan/frontend",
    "dev:backend": "turbo run dev --filter=@betterlibmanan/backend",
    "dev:worker": "turbo run dev --filter=@betterlibmanan/worker",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "turbo run db:migrate --filter=@betterlibmanan/backend",
    "db:seed": "turbo run db:seed --filter=@betterlibmanan/backend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}