# ==========================================
# BetterLibmanan - Environment Configuration
# ==========================================

# ==========================================
# Application Settings
# ==========================================
NODE_ENV=development
APP_NAME=BetterLibmanan
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ==========================================
# Backend
# ==========================================
PORT=5000
HOST=0.0.0.0

# ==========================================
# Database
# ==========================================
MONGODB_URI=mongodb://localhost:27017/betterlibmanan

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# Authentication
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Email
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_HOST=user@example.com
SMTP_PASS=password
MAIL_FROM=noreply@betterlibmanan.gov.ph
ADMIN_EMAIL=lil.studiosx@gmail.com

# ==========================================
# Health Check
# ==========================================
HEALTH_CHECK_INTERVAL_MINUTES=3

# ==========================================
# Storage
# ==========================================
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=betterlibmanan
S3_REGION=us-east-1

# ==========================================
# Monitoring & Logging
# ==========================================
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# ==========================================
# DPWH Government API Proxy
# ==========================================
# Backend proxy that bypasses the upstream API's hard-coded CORS origin
# (http://localhost:3000) AND its Cloudflare bot mitigation, so the
# production frontend can read the data.
DPWH_API_BASE_URL=https://api.transparency.dpwh.gov.ph
# Optional credentials — leave blank if the upstream doesn't require them
DPWH_API_KEY=
DPWH_API_TOKEN=
# Upstream request timeout in milliseconds
DPWH_TIMEOUT_MS=12000
# Optional outbound proxy for the upstream request (HTTP/HTTPS/SOCKS URL).
# REQUIRED IN PRODUCTION if the upstream Cloudflare challenges your server's
# IP (datacenter IPs almost always get challenged, residential ones don't).
# Point this at a residential/mobile proxy, e.g.:
#   DPWH_PROXY_URL=http://user:pass@gateway.provider.com:8000
DPWH_PROXY_URL=
# Origin/Referer the upstream's CORS config whitelisted. We forward these
# even though we're server-to-server, because DPWH inspects them.
DPWH_ORIGIN=http://localhost:3000
DPWH_REFERER=http://localhost:3000/

# ==========================================
# Frontend (Vite) — DPWH Proxy
# ==========================================
# Override only if the proxy is hosted at a different origin than the SPA.
# Defaults to `/api/dpwh` (same-origin) when unset.
# VITE_DPWH_PROXY_BASE_URL=
