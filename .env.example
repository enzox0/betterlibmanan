# ==========================================
# BetterLibmanan - Environment Configuration
# ==========================================
# 
# Environment-specific files (create these for your deployment):
# - .env.development.local (for local development, gitignored)
# - .env.staging (for staging, can be committed if public-safe)
# - .env.production (for production, secrets should be gitignored)
# - .env.*.local (all .local files are gitignored)
#
# Environment-specific files take precedence: .env.<env>.local > .env.<env> > .env
#

# ==========================================
# Application Settings
# ==========================================
NODE_ENV=development
APP_NAME=BetterLibmanan
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ==========================================
# Backend
# ==========================================
# Port configuration by environment
PORT=5000  # Default/development backend port
PORT_STAGING=5001  # Staging backend port
PORT_PRODUCTION=5002  # Production backend port
HOST=0.0.0.0

# ==========================================
# Database
# ==========================================
MONGODB_URI=mongodb://localhost:27017/betterlibmanan

# ==========================================
# Authentication
# ==========================================
JWT_ACCESS_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production  # Deprecated: use JWT_ACCESS_SECRET instead
JWT_ACCESS_TTL=15m      # How long an access token lives (default: 15 minutes)
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_TTL_DAYS=7  # Hard ceiling: max lifetime of a refresh token (default: 7 days)
JWT_REFRESH_EXPIRE=30d
# Inactivity timeout: how many minutes without a refresh call before the
# session is treated as inactive and revoked. Defaults to 30 minutes.
# A frontend that calls /refresh whenever the user is active will keep
# this window from ever triggering for active users.
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Email
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
MAIL_FROM=no-reply@betterlibmanan.org
ADMIN_EMAIL=lil.studiosx@gmail.com

# ==========================================
# Health Check
# ==========================================
HEALTH_CHECK_INTERVAL_MINUTES=3

# ==========================================
# Storage
# ==========================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=betterlibmanan
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com

# ==========================================
# Monitoring & Logging
# ==========================================
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# ==========================================
# DPWH Government API Proxy
# ==========================================
# Architecture: cache-first.
#
# The DPWH transparency API is fronted by Cloudflare and blocks datacenter
# IPs (GCP, AWS, Render, …). Rather than fight that at request time, the
# production backend reads from a MongoDB cache, and a separate refresh
# script (`npm run refresh-dpwh-cache --workspace=apps/backend`) runs from a
# residential connection (typically the developer's Windows machine) to
# keep the cache populated. See `apps/backend/scripts/refresh-dpwh-cache.ts`.
#
# DPWH_API_BASE_URL  — used by the refresh script and the optional live
#                       fallback in the controller.
DPWH_API_BASE_URL=https://api.transparency.dpwh.gov.ph
# Upstream request timeout in milliseconds. Used by the refresh script and
# the live-fallback path. 70s is generous so the residential-side fetch has
# room to breathe even when the upstream is slow.
DPWH_TIMEOUT_MS=70000
# Outbound proxy for live upstream requests. Leave BLANK in production —
# the cache strategy means we don't usually need to reach the upstream
# from the VM. Only set this on the residential machine running the refresh
# script, AND only if your home IP somehow gets flagged by Cloudflare too.
DPWH_PROXY_URL=
# Origin/Referer the upstream's CORS config whitelisted. We forward these
# even though we're server-to-server, because DPWH inspects them.
DPWH_ORIGIN=http://localhost:3000
DPWH_REFERER=http://localhost:3000/

# ==========================================
# Frontend (Vite) — DPWH Proxy
# ==========================================
# Override only if the proxy is hosted at a different origin than the SPA.
# Defaults to `/api/dpwh` (same-origin) when unset.
# VITE_DPWH_PROXY_BASE_URL=

# ==========================================
# Frontend (Vite) — exposed to the browser
# ==========================================
# Only variables prefixed with VITE_ are bundled into client code.
# Get your key at https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Public base URL of the Cloudflare R2 bucket (no trailing slash).
# If you use a custom domain for R2 (e.g. https://assets.betterlibmanan.gov.ph)
# set this so SafeImage can detect and proxy those URLs in addition to *.r2.dev.
# Leave blank if you only use the native *.r2.dev public domain.
VITE_R2_PUBLIC_BASE_URL=https://your-custom-r2-domain.example.com

# Socket.IO server URL.
# In dev this is not needed — the client falls back to http://localhost:5000.
# In production, set this to your backend's public origin if the backend is on
# a different domain or port than the frontend (e.g. https://api.yourdomain.com).
# If the frontend and backend share the same domain (reverse-proxy setup) you can
# leave this empty and VITE_API_URL will be used as the fallback.
VITE_SOCKET_URL=

# Port configuration by environment
VITE_PORT=3000  # Default/development frontend port
VITE_PORT_STAGING=3001  # Staging frontend port
VITE_PORT_PRODUCTION=3002  # Production frontend port
