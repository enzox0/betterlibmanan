# ==========================================
# BetterLibmanan - Environment Configuration
# ==========================================

# ==========================================
# Application Settings
# ==========================================
NODE_ENV=development
APP_NAME=BetterLibmanan
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ==========================================
# Backend
# ==========================================
PORT=5000
HOST=0.0.0.0

# ==========================================
# Database
# ==========================================
MONGODB_URI=mongodb://localhost:27017/betterlibmanan

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# Authentication
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Email
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_HOST=user@example.com
SMTP_PASS=password
MAIL_FROM=noreply@betterlibmanan.gov.ph
ADMIN_EMAIL=lil.studiosx@gmail.com

# ==========================================
# Health Check
# ==========================================
HEALTH_CHECK_INTERVAL_MINUTES=3

# ==========================================
# Storage
# ==========================================
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=betterlibmanan
S3_REGION=us-east-1

# ==========================================
# Monitoring & Logging
# ==========================================
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info