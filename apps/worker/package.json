{
  "name": "@betterlibmanan/worker",
  "version": "1.0.0",
  "private": true,
  "description": "BetterLibmanan Background Worker",
  "main": "../../build/worker/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias -p tsconfig.json --resolve-full-paths && node ../../scripts/remove-js-extensions.js",
    "start": "node ../../build/worker/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"Tests coming soon\""
  },
  "dependencies": {
    "@betterlibmanan/types": "workspace:*",
    "@betterlibmanan/utils": "workspace:*",
    "axios": "^1.16.1",
    "dotenv": "^16.6.1",
    "nodemailer": "^6.10.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.23",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.6.0",
    "typescript": "^7.0.2"
  }
}
