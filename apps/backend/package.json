{
  "name": "@betterlibmanan/backend",
  "version": "1.0.0",
  "private": true,
  "description": "BetterLibmanan Backend API",
  "main": "../../build/backend/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias -p tsconfig.json --resolve-full-paths && node ../../scripts/remove-js-extensions.js",
    "start": "node ../../build/backend/main.js",
    "refresh-dpwh-cache": "tsx scripts/refresh-dpwh-cache.ts",
    "test": "echo \"Tests coming soon\"",
    "test:coverage": "echo \"Coverage coming soon\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo \"Lint coming soon\"",
    "db:migrate": "echo \"Migrations coming soon\"",
    "db:seed": "tsx --tsconfig tsconfig.scripts.json scripts/seed-admin.ts",
    "seed": "tsx --tsconfig tsconfig.scripts.json scripts/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@betterlibmanan/types": "workspace:*",
    "@betterlibmanan/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "got-scraping": "4",
    "helmet": "^7.1.0",
    "imgtowebp": "^0.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "nodemailer": "^8.0.10",
    "winston": "^3.11.0",
    "socket.io": "4.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^8.55.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
