{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ES2022"],
    "outDir": "../../build/backend",
    "rootDir": "src",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "../../build"],
  "references": [
    { "path": "./tsconfig.scripts.json" }
  ]
}